{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "allowJs": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "incremental": true,
    "strict": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@km0lab/app": [
        "packages/app/index.ts"
      ],
      "@km0lab/app/*": [
        "packages/app/*"
      ],
      "@km0lab/ui": [
        "packages/components/index.ts"
      ],
      "@km0lab/ui/*": [
        "packages/components/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "build",
    "dist",
    ".expo",
    ".turbo"
  ]
}
