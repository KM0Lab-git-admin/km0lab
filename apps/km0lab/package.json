{
  "name": "km0lab",
  "private": true,
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "with-dev-env": "dotenv -e env/.env.development -c -- ",
    "with-prod-env": "dotenv -e env/.env.production -c -- ",
    "dev": "pnpm with-dev-env expo start",
    "android": "pnpm with-dev-env expo run:android",
    "ios": "pnpm with-dev-env expo run:ios",
    "web": "pnpm with-dev-env expo start --web",
    "tunnel": "pnpm with-dev-env expo start --tunnel",
    "build:web": "pnpm with-prod-env expo export -p web",
    "prebuild:android": "pnpm with-dev-env expo prebuild -p android --clean",
    "prebuild:ios": "pnpm with-dev-env expo prebuild -p ios --clean",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "type:check": "tsc --noEmit",
    "expo:doctor": "npx expo-doctor@latest"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@km0lab/app": "workspace:*",
    "@km0lab/ui": "workspace:*",
    "@react-navigation/native": "^7.1.28",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.7",
    "expo-font": "^55.0.6",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "lucide-react-native": "^0.546.0",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-css-interop": "^0.2.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.1",
    "react-native-worklets": "0.7.4",
    "tailwindcss": "3.3.5"
  },
  "devDependencies": {
    "@km0lab/eslint-config": "workspace:*",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "~55.0.10",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.36.0",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "~5.9.3"
  }
}
